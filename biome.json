{
  "$schema": "https://biomejs.dev/schemas/2.0.6/schema.json",
  "files": {
    "includes": [
      "**",
      "!dist/**",
      "!node_modules/**",
      "!release/**",
      "!debug/**"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  },
  "linter": {
    "rules": {
      "complexity": {
        "noUselessSwitchCase": "off"
      }
    }
  }
}
